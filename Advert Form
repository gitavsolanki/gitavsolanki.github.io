	input[type=button] {background-color:#DFE1E1;color:#000;border:1px solid  #000;border-radius:5px;padding:5px;cursor:pointer}
	input[type=button].forwards {background-color:#007FA3;color:#FFF;}
	
	select{padding:10px;border:1px solid #007FA3;border-radius:5px;display:inline-block;box-sizing: border-box;}
	table.c{width:100%;border-collapse:collapse}
	table.c td,th{border:1px solid #c0c0c0;padding:5px}
	table.v td{border:5px solid #FFF;width:33%;text-align:left;vertical-align:top}
	table.v td:hover{background: rgba(100, 100, 100, 0.5);cursor:pointer}
	table.v tr{height:33%}
	div.s{max-width:800px;border:10px solid #D4EAE4;;padding:20px;margin-left:auto;margin-right:auto;}
	div.fV{display:none}
	div.b{max-width:840px;margin-left:auto;margin-right:auto;font-size:small}
	div.e{border:10px solid #D4EAE4;padding:20px;}
	div.e span{font-size:36px}
	*{-webkit-box-sizing: border-box;-moz-box-sizing: border-box;box-sizing: border-box;}
	#m {background-color:#eaeaea;padding:5px}
	.logo{height:90px;background:url("data:image/png;base64,") 10px center no-repeat #FFF}

	</style>

	
<script>

function d(id){
	return document.getElementById(id).value}

function p(id){
	return document.getElementById(id).type}

function h(id,v){
	document.getElementById(id).innerHTML=v}

function w(id,v){
	document.getElementById(id).value=v}

function e(){
	r();
	var c=d("firstName")+"_"+d("lastName")+"_Completed.html";
	var o="<!DOCTYPE html>\n"+document.documentElement.outerHTML;
	var blob = new Blob([o], { type: 'text/html;charset=utf-8;' });
	if(window.navigator.msSaveBlob) { //Internet Explorer (must be 10 or above)
		var blob = new Blob([o], { type: 'text/html;charset=utf-8;' });
		window.navigator.msSaveBlob(blob, c);}
	else{ //Other Browsers
		var link = document.createElement("a");
		if (link.download !== undefined) {
			var url = URL.createObjectURL(blob);
			link.setAttribute("href", url);
			link.setAttribute("download", c);
			link.style.visibility = 'hidden';
			document.body.appendChild(link);
			link.click();
			document.body.removeChild(link);}}}

function r() {
	var e = document.querySelectorAll("input.f"); //Must be (IE9 or Above)
	for (var i = 0; i < e.length; i++) {
		V=e[i].value;
		if(e[i].type=="checkbox"||e[i].type=="radio") {
			if(e[i].checked==true)V="checked";
			else V="";}
		h(""+e[i].id+"_V",V);}
	e = document.querySelectorAll("select.f");
	for (i = 0; i < e.length; i++) {
		h(""+e[i].id+"_V",e[i].value);}}

function l() {
	if (window.URL === undefined && window.webkitURL === undefined) {
		document.getElementById("m").innerHTML="The browser does not support the assesssment. Please use a more modern browser, and/or ensure emulation is IE10 or above.";}
	else{
		s(1);
		document.getElementById("e").style.display="none";
		document.getElementById("a").style.display="block";
		var e = document.querySelectorAll("div.fV");
		for (var i = 0; i < e.length; i++) {
			b=(e[i].id).substring(0, e[i].id.length-2);
			if(p(b)=="text") w(b,e[i].textContent);
			if(p(b)=="checkbox"||p(b)=="radio") {
				if(e[i].textContent=="checked") document.getElementById(b).checked=true;
				else document.getElementById(b).checked=false;}
			if(p(b)=="select-one") {
				if(e[i].textContent!="") w(b,e[i].textContent);}}}}

function t(which){
	if(document.getElementById(which).checked==true)document.getElementById(which).checked=false;
	else document.getElementById(which).checked=true;}
	
function s(n){
	for(i=1;i<=5;i++){
		document.getElementById("s"+i).style.display=((n!=i)?"none":"block");}}

function c(field,output){
	document.getElementById(output).innerHTML=field.value;}
	
//Task Specific

function calculatePayTotal(dest){
		advertSize=document.getElementById("advertSize").value
		if(advertSize=="Quarter page"){
			advertCost="20"}
		else if(advertSize=="Half page"){
			advertCost="25"}
		else if(advertSize=="Full page"){
			advertCost="30"}
		else {
			advertCost="-"}
		document.getElementById("advertCost").value="£ "+advertCost;
		document.getElementById("advertCost_V").innerHTML="£ "+advertCost;		
		numberWeeks=document.getElementById("numberWeeks").value
		if(advertCost=="-") {
			document.getElementById(dest).value="£ -";
			document.getElementById(dest+"_V").innerHTML=document.getElementById(dest).value}
		else if(numberWeeks=="-") {
			document.getElementById(dest).value="£ -";
			document.getElementById(dest+"_V").innerHTML=document.getElementById(dest).value}
		else {
			document.getElementById(dest).value="£ "+eval(advertCost*numberWeeks);
			document.getElementById(dest+"_V").innerHTML=document.getElementById(dest).value}
		c(document.getElementById(dest),"amountToPayRepeat1");
		}
		

</SCRIPT>
</Head>
<body>

<form id="a">
	<div id="s1" class="s">
		<div class="logo"></div>
		<h1>Essential Digital Skills Entry Level</h1>
		<h2>Task 4</h2>
		<p>Please enter your personal details.</p>
		<table class="c" width=100%>
			<tr>
