						<option value="Quarter page">Quarter page
						<option value="Half page">Half page
						<option value="Full page">Full page
					</select>
					<div id="advertSize_V" class="fV"></div>
				</td>
			</tr>
		</table><br>
		<table class="c">
			<tr>
				<td style="width:200px">
					<label for="advertCost">Advert cost:</label>
				</td>
				<td>
				
				<input type="text" id="advertCost" autocomplete="off" class="f" style="display:none">
				<div id="advertCost_V" class="fV" style="display:block">£ -</div>
	
				</td>
			</tr>
		</table><br>
		<table class="c">
			<tr>
				<td style="width:200px">
					<label for="numberWeeks">Number of weeks:</label>
				</td>
				<td>
					<select id="numberWeeks" class="f" onchange="calculatePayTotal('payTotal');">
						<option value="-">-
						<option value="1">1
						<option value="2">2
						<option value="3">3
					</select>
					<div id="numberWeeks_V" class="fV"></div>
				</td>
			</tr>
		</table><br>
		<table class="c">
			<tr>
				<td style="width:200px">
					<label for="payTotal">Total to pay:</label>
				</td>
				<td>
					<input type="text" id="payTotal" autocomplete="off" maxlength="16" class="f" READONLY style="display:none">
					<div id="payTotal_V" class="fV" style="display:block">£ -</div>
				</td>
			</tr>
		</table><br>
		<strong>Pay with</strong>
		<table class="c">
		
					<tr>
				<td>
					<label for="CreditCard">Credit Card</label>
				</td>
				<td>
					<input type="radio" id="CreditCard" autocomplete="off" class="f" name=PaymentMethod value="Credit Card">
					<div id="CreditCard_V" class="fV"></div>
				</td>
			</tr>
			
						<tr>
				<td>
					<label for="DebitCard">Debit Card</label>
				</td>
				<td>
					<input type="radio" id="DebitCard" autocomplete="off" class="f" name=PaymentMethod value="Debit Card">
					<div id="DebitCard_V" class="fV"></div>
				</td>
			</tr>
			
						<tr>
				<td>
					<label for="OnlineService">Online Service</label>
				</td>
				<td>
					<input type="radio" id="OnlineService" autocomplete="off" class="f" name=PaymentMethod value="Online Service">
					<div id="OnlineService_V" class="fV"></div>
				</td>
			</tr>
		</table><br>
		
		
		<input type="button" value="Previous" onclick="s(1);">
		<input type="button" value="Next" onclick="s(3);" class="forwards">	
	</div>
	<div id="s3" class="s">
		<H1>Payment Details</H1>
		<table class="c">
			<tr>
				<td>
					<label for="cardNumber">Card Number</label>
				</td>
				<td>
					<input type="text" id="cardNumber" autocomplete="off" class="f">
					<div id="cardNumber_V" class="fV"></div>
				</td>
			</tr>
			<tr>
				<td>
					<label for="expiryDate">Expiry Date</label>
				</td>
				<td>
					<input type="text" id="expiryDate" autocomplete="off" class="f">
					<div id="expiryDate_V" class="fV"></div>
				</td>
			</tr>
			<tr>
				<td>
					<label for="CVV">CVV</label>
				</td>
				<td>
					<input type="text" id="CVV" autocomplete="off" class="f">
					<div id="CVV_V" class="fV"></div>
				</td>
			</tr>
		</table><br>
		<input type="button" value="Previous" onclick="s(2);">
		<input type="button" value="Make payment" onclick="s(4);" class="forwards">	
	</div>
	<div id="s4" class="s">
		<h1>Review your information</h1>
		<table class="c">
			<tr>
				<td>
					<label for="amountToPayRepeat1">Amount to pay</label>
				</td>
				<td>
					<span id="amountToPayRepeat1">£0</span>
				</td>
			</tr>
		</table><br>
		<input type="button" value="Previous" onclick="s(3);">
